{
  "name": "forklift-technical-manifest",
  "version": "1.0.0",
  "description": "Toyota 7FBEU20 Electric Forklift Technical Reference - Built by a maintenance tech using AI",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build-win": "electron-builder --win",
    "build-mac": "electron-builder --mac",
    "build-linux": "electron-builder --linux"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/TheWiredWatchman/forklift-technical-manifest"
  },
  "keywords": [
    "forklift",
    "toyota",
    "7FBEU20",
    "maintenance",
    "technical-reference",
    "electron",
    "ai-assisted",
    "troubleshooting",
    "error-codes",
    "preventive-maintenance"
  ],
  "author": "Joseph Overberg <joseph@thewiredwatchman.com> (https://thewiredwatchman.com)",
  "license": "MIT",
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1"
  },
  "build": {
    "appId": "com.thewiredwatchman.forklift-manifest",
    "productName": "Forklift Technical Manifest",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "index.html",
      "package.json"
    ],
    "win": {
      "target": "nsis",
      "icon": "icon.ico"
    },
    "mac": {
      "target": "dmg",
      "icon": "icon.icns"
    },
    "linux": {
      "target": "AppImage",
      "icon": "icon.png"
    }
  }
}
